# ═══════════════════════════════════════════
# SmartTable — Variables d'environnement
# Copier vers smarttable-backend/.env et docker-compose
# ═══════════════════════════════════════════

# --- Application ---
APP_NAME=SmartTable
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5175

# --- Base de données ---
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=smarttable
DB_USERNAME=smarttable
DB_PASSWORD=secret
DB_ROOT_PASSWORD=rootsecret

# --- Cache & sessions ---
CACHE_DRIVER=file
SESSION_DRIVER=file
SESSION_DOMAIN=localhost
SESSION_LIFETIME=120
QUEUE_CONNECTION=sync

# --- Sanctum / CORS ---
SANCTUM_STATEFUL_DOMAINS=localhost:5175,127.0.0.1:5175

# --- IA & Chatbot ---
OPENAI_API_KEY=
N8N_WEBHOOK_URL=http://localhost:5678/webhook/smarttable-chat

# --- WhatsApp (Twilio) — plans Pro / Enterprise ---
TWILIO_SID=
TWILIO_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# --- Stockage fichiers ---
FILESYSTEM_DISK=local
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-1
# AWS_BUCKET=
# AWS_USE_PATH_STYLE_ENDPOINT=false

# --- Email ---
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=hello@smarttable.ma
MAIL_FROM_NAME="${APP_NAME}"

# --- Images menus (optionnel) ---
PEXELS_API_KEY=
UNSPLASH_ACCESS_KEY=
MENU_IMAGE_FALLBACK_URL=

# --- Frontend (Vercel) ---
VITE_API_URL=http://localhost:8000/api
